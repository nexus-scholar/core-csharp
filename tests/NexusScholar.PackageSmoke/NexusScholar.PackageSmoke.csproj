<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <RestorePackagesPath>$(MSBuildThisFileDirectory).packages</RestorePackagesPath>
    <RestoreLockedMode>false</RestoreLockedMode>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="NexusScholar.Bundles" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Extensibility" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Network" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Reporting" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Synthesis" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Screening.CorpusSnapshots" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Screening.FullText" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Screening.WorkflowExecution" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.Search" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.WorkflowExecution.Provenance" Version="0.1.0-alpha.2" />
    <PackageReference Include="NexusScholar.WorkflowExecution.ScientificRecords" Version="0.1.0-alpha.2" />
  </ItemGroup>
  <ItemGroup>
    <None Include="../../eng/package-topology.json" Link="package-topology.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
